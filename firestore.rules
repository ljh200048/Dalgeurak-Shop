rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@dalgeurak.com' || 
        request.auth.token.email == 'lch200048@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Classes: Public read, Admin write
    match /classes/{classId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Products: Public read, Admin write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Reservations (Bookings): Anyone can create (to allow guests), owner or admin can update/delete
    match /reservations/{reservationId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 4. Reviews: Public read, Authenticated write, owner or admin can delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 5. Gallery: Public read, Authenticated write, owner or admin can delete
    match /gallery/{galleryId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 6. Notices: Public read, Admin write
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Coupons: Public/Auth read, Admin write
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 8. User Profiles: Owner or Admin can read/write
    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(userId);
    }

    // 9. Settings: Public read, Admin write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
